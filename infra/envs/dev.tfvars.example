# ─────────────────────────────────────────────────────────────────────────────
# dev / LAB INSTANCE of pyre. Copy to dev.tfvars and fill in the <...> values.
# Same composition as prod — only the values differ (cheaper SKUs, lab access,
# a mock-only destination). This is the file tools/LAB.md walks you through.
#
#   # bootstrap remote state once (tools/LAB.md Part 3), fill infra/backend.tf, then:
#   terraform -chdir=infra init -backend-config="key=dev.tfstate"
#   terraform -chdir=infra apply -var-file=envs/dev.tfvars
#
# Deploys the SAME secure architecture as prod (all private, Entra-only), just
# cheaper SKUs. Two explicit choices keep it off production — NEITHER depends on
# `env`:
#   1. default_routes = ["mock"]  — alerts can only ever reach the mock sink
#   2. no production destination is declared at all
# Everything is fully private (no public endpoints, no IP allowlist); deploy from
# inside the VNet. See tools/PRODUCTION_CHECKLIST.md section 1.
# ─────────────────────────────────────────────────────────────────────────────

name_prefix         = "pyredev" # globally unique across ALL instances (storage/KV/EH names)
env                 = "dev"
location            = "westus2"
resource_group_name = "rg-pyre-dev"
cost_profile        = "test"             # cheapest SKUs: Managed Redis Balanced_B0, 1 TU Event Hubs, Flex 0 always-ready
owner               = "<your object id>" # az ad signed-in-user show --query id -o tsv

# Everything is always private, reached only from inside the VNet - there is no
# IP allowlist. Run terraform/func/pyre/log-shipping from a VNet-resident agent.

# --- Identities: YOU are both ------------------------------------------------
# Grant the two external roles to your own user so your `az login` can act as the
# log sender AND the bundle publisher. "managed_identity" mode just means "an
# object ID that already exists" — here, yours.
log_sender = { mode = "managed_identity", principal_id = "<your object id>" }
publisher  = { mode = "managed_identity", principal_id = "<your object id>" }
#
# In a REAL dev instance (deployed from CI/an agent, not a laptop) these become
# the shipper's and CI's identities instead. Four worked shapes:
#   A. shipper is an Azure resource (Cribl on a VM/VMSS/Container App):
#      log_sender = { mode = "managed_identity", principal_id = "<that identity's object id>" }
#   B. CI outside Azure (GitHub Actions — the temporary, non-prod path):
#      publisher = { mode = "federated", federated_credentials = [{
#        name = "github-main", issuer = "https://token.actions.githubusercontent.com",
#        subject = "repo:<org>/<repo>:ref:refs/heads/main" }] }
#   C. CI on a self-hosted ADO agent that IS Azure compute (the prod path):
#      publisher = { mode = "managed_identity", principal_id = "<agent VM's identity object id>" }
#   D. CI on ADO Microsoft-hosted agents (needs a federated WIF service connection):
#      publisher = { mode = "federated", federated_credentials = [{
#        name = "ado-pyre-publisher", issuer = "<issuer ADO shows>", subject = "<subject ADO shows>" }] }

# --- Network (distinct per instance so they can peer later) ------------------
address_space           = "10.0.0.0/16"
pe_subnet_prefix        = "10.0.1.0/24"
functions_subnet_prefix = "10.0.2.0/24"

# --- Who may change this instance --------------------------------------------
# Your own object id, so you can run terraform apply here. In the company, list a
# group id and add people to the group (no terraform run). Empty grants nobody.
#   az ad signed-in-user show --query id -o tsv
admin_principal_ids = ["<your object id>"]

# --- Engine tuning: minimal for a single low-volume feed ---------------------
worker_process_count = 1 # one bundle copy in the 2 GB instance; raise for real volume
threads_per_worker   = 1 # a single-user lab needs no I/O overlap
# Feed shape (log-type field, event-time field, envelope) is declared PER
# NAMESPACE in config/sources.yaml, not here. The default `cribl` namespace is
# already dataset / _time / no-envelope - what testlab samples stamp.

# --- Alert destinations: the mock is the ONLY sink ---------------------------
# The mock Function App (<name_prefix>-mockdest) does not exist until LAB.md
# Part 6. This URL is its DERIVED name, so it is correct the moment you deploy
# the mock — but you MUST restart the processor after first setting it, because
# destinations are read at STARTUP (only detections hot-reload):
#   az functionapp restart -n <name_prefix>-proc -g <resource_group_name>
# No token_secret: a mock needs no auth, so no Key Vault secret is created.
destinations = {
  mock = { url = "https://pyredev-mockdest.azurewebsites.net/api/alert" }
}

# Where an alert goes when its detection names no destination itself. THIS — not
# `env`, not destinations.yaml's `enabled:` — is what keeps a lab off production.
# This instance declares NO production destination above, so even a typo here
# cannot page prod: the adapter would have no URL/token and fail closed and loud.
default_routes = ["mock"]

# signals_sink_url is intentionally unset in a lab: no Cribl lake, so signals are
# discarded and only alerts reach the mock (expected — see LAB.md §9).
# signals_sink_url = "https://<cribl-http-source>"
